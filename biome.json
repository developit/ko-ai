{
    "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
    "vcs": {
      "enabled": false,
      "clientKind": "git",
      "useIgnoreFile": true
    },
    "files": {
      "ignoreUnknown": false,
      "ignore": []
    },
    "formatter": {
      "enabled": true,
      "indentStyle": "space",
      "indentWidth": 2
    },
    "organizeImports": {
      "enabled": true
    },
    "linter": {
      "enabled": true,
      "rules": {
        "recommended": true,
        "a11y": {
          "useButtonType": "off",
          "all": false
        },
        "style": {
          "useConst": "warn",
          "useTemplate": "off",
          "noUselessElse": "warn",
          "noParameterAssign": "off",
          "useNumberNamespace": "off"
        },
        "complexity": {
          "useOptionalChain": "warn",
          "useArrowFunction": "off"
        },
        "correctness": {
          "useJsxKeyInIterable": "off",
          "noChildrenProp": "off"
        },
        "suspicious": {
          "noAssignInExpressions": "off",
          "noExplicitAny": "off"
        }
      }
    },
    "javascript": {
      "formatter": {
        "quoteStyle": "single",
        "lineWidth": 120,
        "bracketSpacing": false
      }
    }
  }
