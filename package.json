{
  "name": "ko-ai",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "author": "Jason Miller (https://jasonformat.com)",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./agent": {
      "types": "./dist/agent.d.ts",
      "import": "./dist/agent.js"
    },
    "./agent-tools": {
      "types": "./dist/agent-tools.d.ts",
      "import": "./dist/agent-tools.js"
    },
    "./agent-signals": {
      "types": "./dist/agent-signals.d.ts",
      "import": "./dist/agent-signals.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsup --clean",
    "build-demo": "pnpm --filter demo build",
    "dev": "tsup --watch",
    "test": "node --test **/*.test.ts",
    "test:watch": "node --test --watch **/*.test.ts",
    "test:record": "KOAI_TEST_MODE=record node --test **/*.test.ts",
    "test:validate": "node test/validate-fixtures.ts",
    "pretest": "pnpm run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "@preact/signals-core": ">=1.14.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@preact/signals-core": "^1.14.0",
    "@types/node": "^24.10.1",
    "mock-openai-api": "^1.0.3",
    "nock": "^14.0.10",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
